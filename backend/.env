# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# when starting with the all app
DATABASE_NAME="postgres"
DATABASE_PORT="5432"

DATABASE_URL="postgresql://ethan:123@postgres:5432/mydb?schema=public"
JWT_SECRET='super-secret'

# # when starting only backend
# DATABASE_NAME="postgres"
# DATABASE_PORT="5434"

# DATABASE_URL="postgresql://ethan:123@postgres:5434/mydb?schema=public"
# JWT_SECRET='super-secret'

HOSTNAME=85af9cd2d59e
HOME=/root
OLDPWD=/
PG_VERSION=13.10-1.pgdg110+1
TERM=xterm
POSTGRES_PASSWORD=123
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/lib/postgresql/13/bin
POSTGRES_USER=ethan
LANG=en_US.utf8
PG_MAJOR=13
GOSU_VERSION=1.16
PWD=/var/lib/postgresql/data
POSTGRES_DB=mydb
PGDATA=/var/lib/postgresql/data